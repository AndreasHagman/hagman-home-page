# Google account email(s) allowed admin access (comma-separated)
ADMIN_EMAIL=you@example.com

# Phone number(s) allowed admin access in E.164 format (comma-separated)
ADMIN_PHONE=+4700000000

# Firebase client SDK (browser — image display & Storage uploads)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server — session verification & Firestore writes)
# Generate from Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
